{
  "name": "tomo",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "tomo": "dist/tomo.js"
  },
  "scripts": {
    "build": "tsup",
    "build:sea": "bash scripts/build-sea.sh",
    "dev": "exec tsx src/index.tsx",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "prepare": "lefthook install",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "4.1.0",
    "ink-testing-library": "^4.0.0",
    "lefthook": "^2.1.4",
    "msw": "^2.12.14",
    "react-devtools-core": "^7.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook"
    ]
  },
  "packageManager": "pnpm@10.11.1",
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "diff": "^8.0.3",
    "ink": "^6.8.0",
    "marked": "^17.0.4",
    "react": "^19.2.4",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  }
}
